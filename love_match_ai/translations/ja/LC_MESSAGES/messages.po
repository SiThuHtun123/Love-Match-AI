msgstr "新しいマッチ"

#: templates/base.html:19 templates/history.html:2
msgid "History"
msgstr "履歴"

#: templates/base.html:20 templates/halloffame.html:2
#: templates/halloffame.html:4
msgid "Hall of Fame"
msgstr "殿堂"

