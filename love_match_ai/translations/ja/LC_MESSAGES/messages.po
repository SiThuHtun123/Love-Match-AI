#: app.py:65
msgid "Please log in first — love waits for no one! 💘"
msgstr "まずはログインしてください——愛は誰も待ってくれません！💘"

#: app.py:136
#, python-format
msgid ""
"%(who)s: I see %(count)d people in this photo! I'm an AI, not a "
"matchmaker for a whole party 🎉 — one face per photo, please!"
msgstr ""
"%(who)s：この写真には%(count)d人写っています！私はAIであって、パーティー全員の仲人ではありません🎉 "
"1枚につき1人の顔でお願いします！"

#: app.py:142
#, python-format
msgid ""
"%(who)s: Hmm, I can't find a clear face in this photo. Try a brighter, "
"front-facing one! 📷"
msgstr "%(who)s：うーん、この写真からはっきりした顔が見つかりません。明るい正面向きの写真を試してください！📷"

#: app.py:173
msgid "Username must be 3–20 characters."
msgstr "ユーザー名は3〜20文字で入力してください。"

#: app.py:175
msgid "Password must be at least 6 characters."
msgstr "パスワードは6文字以上で入力してください。"

#: app.py:177
msgid "Passwords do not match."
msgstr "パスワードが一致しません。"

#: app.py:179
msgid "That username is already taken."
msgstr "そのユーザー名はすでに使われています。"

#: app.py:186
#, python-format
msgid "Welcome aboard, %(name)s! Time to find your match 💘"
msgstr "ようこそ、%(name)sさん！さっそく運命の相手を探しましょう💘"

#: app.py:201
#, python-format
msgid "Welcome back, %(name)s! 💖"
msgstr "おかえりなさい、%(name)sさん！💖"

#: app.py:203
msgid "Wrong username or password. Even the AI can't match those."
msgstr "ユーザー名またはパスワードが違います。これはAIでもマッチングできません。"

#: app.py:211
msgid "Logged out. Cupid will miss you! 👋"
msgstr "ログアウトしました。キューピッドが寂しがっています！👋"

#: app.py:237 templates/match.html:25
msgid "Me"
msgstr "わたし"

#: app.py:239
msgid "Please upload your own photo first! 📷"
msgstr "まずはあなた自身の写真をアップロードしてください！📷"

#: app.py:245
msgid "Your photo doesn't look like a valid image file."
msgstr "あなたの写真は有効な画像ファイルではないようです。"

#: app.py:247
msgid "Your photo"
msgstr "あなたの写真"

#: app.py:256
#, python-format
msgid "Candidate %(num)d"
msgstr "候補者%(num)d"

#: app.py:262
#, python-format
msgid "%(who)s: that file doesn't look like a valid image."
msgstr "%(who)s：このファイルは有効な画像ではないようです。"

#: app.py:268
msgid "Add at least one candidate — the AI can't matchmake thin air! 💨"
msgstr "候補者を最低1人追加してください——AIは空気とはマッチングできません！💨"

#: app.py:354
msgid "Match renamed! ✏️"
msgstr "マッチ名を変更しました！✏️"

#: app.py:367
msgid "Match deleted. The AI has already forgotten them. 🗑️"
msgstr "マッチを削除しました。AIはもう忘れました🗑️"

#: app.py:406
msgid "This page ghosted you. It's not here. 👻"
msgstr "このページはあなたをゴースティングしました。ここにはありません👻"

#: app.py:412
msgid "The AI fainted from too much love. Try again!"
msgstr "AIは愛が多すぎて気絶しました。もう一度お試しください！"

#: app.py:417
msgid "That photo is too large (max 8 MB per request). Try a smaller one!"
msgstr "写真が大きすぎます（1回あたり最大8MB）。小さいものをお試しください！"

#: app.py:423
msgid "Your session expired — please try again."
msgstr "セッションの有効期限が切れました。もう一度お試しください。"

#: templates/_overlay.html:3
msgid "Analyzing love…"
msgstr "愛を分析中…"

