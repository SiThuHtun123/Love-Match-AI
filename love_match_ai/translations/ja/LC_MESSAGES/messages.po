msgstr "候補者を追加"

#: templates/match.html:59
msgid "Find My Match!"
msgstr "マッチを探す！"

#: templates/register.html:6
msgid "Create your account"
msgstr "アカウントを作成"

#: templates/register.html:7
msgid "Destiny is one form away."
msgstr "運命まで、あとフォーム1つ。"

#: templates/register.html:19
